PORT=4000
CLIENT_URL=https://your-demo-frontend-url
ALLOWED_ORIGINS=https://your-demo-frontend-url,https://demo.example.com
# Set TRUST_PROXY=true behind Railway/Vercel/reverse proxies so rate limiting sees X-Forwarded-For correctly.
# Production should usually set this true. Local development can leave it unset/false unless testing behind a proxy.
TRUST_PROXY=true
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_mysql_database
JWT_SECRET=your_long_random_secret
JWT_EXPIRES_IN=1h
DEMO_PASSWORD=your_demo_password
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_INVITE_ACCESS_MAX=15
RATE_LIMIT_OWNER_INVITE_MAX=20
RATE_LIMIT_DEV_MULTIPLIER=10
# Billing Stripe mode defaults to test when unset. Use live only for production cutover.
BILLING_STRIPE_MODE=test
# Never commit real Stripe keys. Test mode must use sk_test_..., live mode must use sk_live_...
STRIPE_SECRET_KEY=
# Use the Stripe CLI or Stripe test dashboard webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=
STRIPE_FOUNDER_PRICE_ID=
STRIPE_REGULAR_PRICE_ID=
STRIPE_SUCCESS_URL=https://your-frontend-url/billing?checkout=success
STRIPE_CANCEL_URL=https://your-frontend-url/billing?checkout=cancel
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://your-frontend-url/billing
BILLING_TRIAL_DAYS=30
# In production, omit this or set true so billing enforcement stays on.
# In development, you can set false temporarily if you need a local bypass.
# BILLING_ENFORCEMENT_ENABLED=true
